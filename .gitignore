# =============================================================================
# Neon-Crate .gitignore — 基于真实项目树扫描生成
# 技术栈：Next.js 14 + FastAPI + SQLite + Docker AIO
# 最后更新：2026-03-20（全量树状图核对版）
# =============================================================================


# =============================================================================
# 【高危敏感文件】绝对隔离 — 泄露即全盘密钥暴露
# =============================================================================

# 运行时数据目录：含 Fernet 主密钥、管理员账号、加密 API Keys、SQLite 数据库
# 树状图确认路径：backend/data/{secret.key,auth.json,secure_keys.json,config.json,media_database.db*}
backend/data/

# docker-compose 将 ./data 挂载至 /app/data，此处一并覆盖
data/

# 环境变量 — 精确列举，避免通配符误杀
.env
.env.local
.env.production
.env.staging
frontend/.env
frontend/.env.local
frontend/.env.local.bak
frontend/.env.development.local
frontend/.env.production.local
frontend/.env.test.local
backend/.env

# 保留模板文件（可入库供协作者参考）
!backend/.env.example


# =============================================================================
# 【Python 后端】构建产物、缓存、虚拟环境
# =============================================================================

# 字节码缓存
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# 虚拟环境 — 树状图确认：backend/venv/ 真实存在，需精确匹配
backend/venv/
.venv/
venv/
env/
ENV/

# 打包产物
build/
dist/
develop-eggs/
.eggs/
*.egg-info/
*.egg
sdist/
wheels/
MANIFEST
lib64/
parts/
var/

# 测试覆盖率
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
dmypy.json

# 本地运维脚本 — 树状图确认：以下文件真实存在
backend/force_refresh_config.py
backend/refresh_config.py
backend/scripts/

# AIO 多阶段构建注入目录（Dockerfile COPY --from=frontend-builder 自动注入，禁止手动提交）
# 树状图确认：backend/static/docs/{swagger-ui-bundle.js,...} 真实存在
backend/static/

# 运行时生成的 OpenAPI schema（FastAPI 自动生成）
backend/openapi.json


# =============================================================================
# 【前端 Next.js】构建产物、缓存、依赖
# =============================================================================

# Next.js 构建输出 — 树状图确认：frontend/.next/ 和 frontend/out/ 均真实存在
frontend/.next/
frontend/out/

# Next.js 缓存
frontend/.cache/

# Node 依赖 — 树状图确认：frontend/node_modules/ 真实存在
frontend/node_modules/
node_modules/

# TypeScript 增量编译缓存 — 树状图确认：frontend/tsconfig.tsbuildinfo 真实存在
frontend/tsconfig.tsbuildinfo
tsconfig.tsbuildinfo

# npm / yarn / pnpm 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*


# =============================================================================
# 【数据库 & 日志】运行时持久化文件
# =============================================================================

# SQLite 及 WAL 模式附属文件 — 树状图确认：media_database.db/.db-shm/.db-wal 真实存在
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# 运行日志 — 树状图确认：backend/data/logs/app.log 真实存在（已被 backend/data/ 覆盖，此处全局兜底）
*.log
logs/


# =============================================================================
# 【GitNexus】知识图谱索引（本地工具生成，不入库）
# =============================================================================

# 树状图确认：.gitnexus/ 真实存在
.gitnexus/

# GitNexus analyze 自动生成的上下文文件
CLAUDE.md
AGENTS.md


# =============================================================================
# 【AI 工具】本地 Skills 配置
# =============================================================================

# 树状图确认：.claude/skills/gitnexus/... 真实存在
.claude/


# =============================================================================
# 【IDE & 编辑器】个人本地配置
# =============================================================================

# 树状图确认：.cursor/ 真实存在
.cursor/

.vscode/
.idea/
*.iml
*.swp
*.swo
*~
\#*\#
.#*


# =============================================================================
# 【操作系统】系统残留文件
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Windows / WSL Zone.Identifier
*.Zone.Identifier


# =============================================================================
# 【临时文件 & 杂项】
# =============================================================================

*.tmp
*.bak
*.orig
*.tar.gz
*.zip


# =============================================================================
# 【个人文档 & 本地工具】不纳入版本控制
# =============================================================================

# 历史报告、开发日志、技术参考资料、CLI 工具文档
# 树状图确认：以上目录均真实存在且内容丰富
docs/历史报告/
docs/开发日志/
docs/技术参考/
docs/CLI工具/

# 演示组件 — 树状图确认：frontend/components/demo/ 和 frontend/app/demo/ 真实存在
frontend/components/demo/
frontend/app/demo/

# 本地测试工具 — 树状图确认：backend/tests/ 真实存在
backend/tests/
