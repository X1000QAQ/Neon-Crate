# Neon Crate - 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 应用配置
APP_NAME="Neon Crate"
APP_VERSION="1.0.0"
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# CORS 配置（前端地址）
# [必填] 生产环境前后端分离部署时，必须配置前端的实际访问域名（带协议），多个用逗号分隔
# 示例（分离部署）：CORS_ORIGINS=["https://your-domain.com","https://www.your-domain.com"]
# 示例（AIO 一体化部署）：前端走相对路径，此项不影响功能，保持默认即可
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Docker 统一存储根（硬链接保障）
DOCKER_STORAGE_PATH=/storage

# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
